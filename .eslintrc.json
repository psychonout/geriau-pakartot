{
  "env": {
    "browser": true,
    "es2021": true,
    "webextensions": true,
    "jquery": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "globals": {
    "chrome": "readonly",
    "$": "readonly",
    "jQuery": "readonly"
  },
  "ignorePatterns": [
    "src/jquery-3.6.0.min.js",
    "dist/**",
    "node_modules/**"
  ],
  "rules": {
    "indent": ["error", 4],
    "linebreak-style": "off",
    "quotes": ["warn", "single"],
    "semi": ["warn", "always"],
    "no-unused-vars": "off",
    "no-console": "off",
    "no-undef": "error",
    "no-case-declarations": "off",
    "no-cond-assign": "warn",
    "no-empty": "warn"
  }
}
